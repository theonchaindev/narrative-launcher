# ============================================================
# Narrative Launcher — Environment Variables
# Copy to .env.local for local development
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/narrative_launcher

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- X (Twitter) API ---
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BOT_HANDLE=NarrativeLaunch

# --- Provider: pump.fun / PumpPortal ---
PUMPPORTAL_API_KEY=
PUMP_PROVIDER_ENABLED=true

# --- Provider: Bags ---
BAGS_API_KEY=
BAGS_API_BASE_URL=https://api.bags.fm
BAGS_PROVIDER_ENABLED=true

# --- Provider: BONK / LetsBonk ---
# Master kill switch — starts disabled; enable after verified test launches
BONK_PROVIDER_ENABLED=false
BONK_API_KEY=
BONK_API_BASE_URL=https://api.letsbonk.io
BONK_LAUNCHLAB_PROGRAM_ID=

# --- Platform ---
PLATFORM_FEE_WALLET=
PLATFORM_FEE_BPS=50

# --- Solana RPC ---
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
QUICKNODE_RPC_URL=

# --- IPFS (fallback) ---
NFT_STORAGE_KEY=

# --- Analytics ---
POSTHOG_KEY=
SENTRY_DSN=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001
